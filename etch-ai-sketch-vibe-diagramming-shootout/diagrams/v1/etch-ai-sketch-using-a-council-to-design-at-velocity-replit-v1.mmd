flowchart TD
  classDef spark    fill:#c46a2c,stroke:#e6a03c,color:#0f172a
  classDef think    fill:#1c3a34,stroke:#c46a2c,color:#e5e7eb
  classDef gate     fill:#5b3a27,stroke:#e6a03c,color:#e5e7eb
  classDef revise   fill:#676a2c,stroke:#e6a03c,color:#e5e7eb
