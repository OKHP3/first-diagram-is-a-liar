    direction TB
        E["Angles + notes"]
        F["Draft post"]
        G["Mermaid V1"]
        H["Honest?"]
        I["Add forks + loops"]
        J["Kill clutter ✂️"]
        K["Now it earns trust"]
  end
 subgraph S3["**3. Proof + publish** · _show the work, then ship it_"]
    direction TB
        L["Write around the proof:\n**hook → thesis → diagram → CTA**"]
        M["Diagram + code images"]
        N["Clear in 5 seconds?"]
        O(("Ship 🚀"))
        P["OverKill Hill P³™"]
        Q["Comments → V2"]
  end
